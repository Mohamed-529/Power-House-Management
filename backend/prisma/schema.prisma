generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./transitops_local.db"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String   @default("FLEET_MANAGER")
  createdAt DateTime @default(now())
}

model Vehicle {
  id             Int              @id @default(autoincrement())
  regNumber      String           @unique
  model          String
  type           String
  maxCapacityKg  Float
  odometer       Float            @default(0)
  acquisitionCost Float
  status         String           @default("AVAILABLE")
  
  trips          Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs       FuelLog[]
  expenses       Expense[]
}

model Driver {
  id            Int          @id @default(autoincrement())
  name          String
  licenseNumber String       @unique
  category      String
  expiryDate    DateTime
  contactNumber String
  safetyScore   Float        @default(100.0)
  status        String       @default("AVAILABLE")
  
  trips         Trip[]
}

model Trip {
  id              Int        @id @default(autoincrement())
  source          String
  destination     String
  cargoWeightKg   Float
  plannedDistance Float
  status          String     @default("DRAFT")
  startOdometer   Float?
  endOdometer     Float?
  fuelConsumed    Float?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  vehicleId       Int
  vehicle         Vehicle    @relation(fields: [vehicleId], references: [id])

  driverId        Int
  driver          Driver     @relation(fields: [driverId], references: [id])
}

model MaintenanceLog {
  id          Int      @id @default(autoincrement())
  description String
  cost        Float
  startDate   DateTime @default(now())
  endDate     DateTime?
  isClosed    Boolean  @default(false)

  vehicleId   Int
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model FuelLog {
  id        Int      @id @default(autoincrement())
  liters    Float
  cost      Float
  date      DateTime @default(now())

  vehicleId Int
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model Expense {
  id          Int      @id @default(autoincrement())
  type        String
  cost        Float
  date        DateTime @default(now())
  description String?

  vehicleId   Int
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}
